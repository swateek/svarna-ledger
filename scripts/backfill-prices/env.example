# Copy to this directory as `.env`:
#   cp env.example .env
#
# From Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

# Project URL
SUPABASE_URL=https://xxxx.supabase.co

# Publishable key (sb_publishable_...) — frontend / read-only via RLS
# Replaces legacy "anon" key
SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...) — scraper, migration, GitHub Actions only
# Replaces legacy "service_role" key. Never commit or expose in the browser.
SUPABASE_SECRET_KEY=
